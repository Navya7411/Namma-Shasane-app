<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Screen title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/decode_title"
            android:textColor="@color/amber_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/decode_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="20dp" />

        <!-- Camera preview area -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_decode_camera_area">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📜"
                    android:textSize="52sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Point camera at inscription"
                    android:textColor="@color/amber_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="or upload a photo below"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Corner brackets for scan frame -->
            <View
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="top|start"
                android:layout_margin="16dp"
                android:background="@color/transparent" />

        </FrameLayout>

        <!-- Action buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_camera"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="10dp"
            android:text="@string/btn_camera"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/dark_bg_primary"
            app:backgroundTint="@color/amber_primary"
            app:cornerRadius="10dp"
            app:icon="@drawable/ic_camera"
            app:iconTint="@color/dark_bg_primary"
            app:iconGravity="start"
            app:iconPadding="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_upload"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="24dp"
            android:text="@string/btn_upload"
            android:textSize="15sp"
            android:textColor="@color/amber_primary"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/amber_primary"
            app:strokeWidth="1.5dp"
            app:cornerRadius="10dp"
            app:icon="@drawable/ic_upload"
            app:iconTint="@color/amber_primary"
            app:iconGravity="start"
            app:iconPadding="8dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_color"
            android:layout_marginBottom="20dp" />

        <!-- How it works section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/decode_tip_title"
            android:textColor="@color/amber_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginBottom="14dp" />

        <!-- Tip 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp"
            android:gravity="top">

            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="1"
                android:textColor="@color/dark_bg_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_marker_found" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:layout_marginTop="4dp"
                android:text="@string/decode_tip_1"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4" />
        </LinearLayout>

        <!-- Tip 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp"
            android:gravity="top">

            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="2"
                android:textColor="@color/dark_bg_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_marker_verified" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:layout_marginTop="4dp"
                android:text="@string/decode_tip_2"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4" />
        </LinearLayout>

        <!-- Tip 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp"
            android:gravity="top">

            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="3"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_marker_atrisk" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:layout_marginTop="4dp"
                android:text="@string/decode_tip_3"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4" />
        </LinearLayout>

        <!-- Supported scripts card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/dark_bg_card"
            app:cardCornerRadius="10dp"
            app:strokeColor="@color/amber_dark"
            app:strokeWidth="1dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:text="@string/decode_supported"
                android:textColor="@color/amber_primary"
                android:textSize="12sp"
                android:gravity="center"
                android:fontFamily="sans-serif-medium" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
