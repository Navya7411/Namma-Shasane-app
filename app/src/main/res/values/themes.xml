<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.NammaShasane" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/amber_primary</item>
        <item name="colorPrimaryVariant">@color/amber_dark</item>
        <item name="colorOnPrimary">@color/dark_bg_primary</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/amber_light</item>
        <item name="colorOnSecondary">@color/dark_bg_primary</item>

        <!-- Background colors -->
        <item name="android:colorBackground">@color/dark_bg_primary</item>
        <item name="colorSurface">@color/dark_bg_secondary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/dark_bg_primary</item>
        <item name="android:navigationBarColor">@color/dark_bg_secondary</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Error color -->
        <item name="colorError">@color/status_at_risk</item>
    </style>

    <!-- Card style -->
    <style name="CardStyle.NammaShasane" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/dark_bg_card</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
        <item name="strokeColor">@color/divider_color</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Bottom Navigation style -->
    <style name="BottomNavStyle.NammaShasane" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/bottom_nav_bg</item>
        <item name="itemIconTint">@color/bottom_nav_icon_selector</item>
        <item name="itemTextColor">@color/bottom_nav_icon_selector</item>
    </style>

    <!-- Button styles -->
    <style name="ButtonStyle.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/amber_primary</item>
        <item name="android:textColor">@color/dark_bg_primary</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ButtonStyle.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/amber_primary</item>
        <item name="android:textColor">@color/amber_primary</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Text input style -->
    <style name="TextInputStyle.NammaShasane" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/amber_primary</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_muted</item>
        <item name="boxBackgroundColor">@color/dark_bg_card</item>
        <item name="errorTextColor">@color/status_at_risk</item>
    </style>

    <!-- Base text style to allow dot-notation inheritance -->
    <style name="TextStyle" parent="android:Widget.TextView">
    </style>

    <!-- Section header text -->
    <style name="TextStyle.SectionHeader">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/amber_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Inscription title text -->
    <style name="TextStyle.InscriptionTitle">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Subtitle text -->
    <style name="TextStyle.Subtitle">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

</resources>
